app:
  name: "youdao-api"
  version: "1.0.0"
  mode: "debug"
  port: 8080

database:
  mysql:
    host: "localhost"
    port: 3306
    username: "root"
    password: "your_password"
    database: "your_database"
    max_idle_conns: 10
    max_open_conns: 100
  redis:
    host: "localhost"
    port: 6379
    password: ""
    db: 0
    pool_size: 10

jwt:
  secret: "your-secret-key-here"
  access_token_exp: "15m"
  refresh_token_exp: "24h"
  issuer: "mindtrace"

external:
  markitdown:
    url: "http://localhost:8085"
  asr:
    provider: "aliyun_nls"
    params:
      access_key_id: "your_key_id"
      access_key_secret: "your_key_secret"
      app_key: "your_app_key"
  minio:
    endpoint: "localhost:9000"
    access_key: "minioadmin"
    secret_key: "minioadmin"
    bucket: "youdaonotelm"
  milvus:
    address: "localhost:19530"
    username: ""
    password: ""
  # Vector embedding model is configured per user in user_config with config_type=embedding.
  bocha:
    base_url: "https://api.bochaai.com"
    endpoint: "/v1/web-search"
    api_key: ""
    timeout_seconds: 15
    default_count: 5
    summary: true
    cache_ttl_seconds: 300
    max_count: 10

log:
  level: "debug"
  filename: "logs/app.log"
  max_size: 100
  max_backups: 3
  max_age: 28
  compress: true

cors:
  enabled: true
  allow_origins:
    - "*"
  allow_methods:
    - "GET"
    - "POST"
    - "PUT"
    - "PATCH"
    - "DELETE"
    - "OPTIONS"
  allow_headers:
    - "Authorization"
    - "Content-Type"
    - "Origin"
    - "Accept"
  expose_headers:
    - "Content-Length"
  allow_credentials: true
  max_age: 86400

email:
  host: "smtp.qq.com"
  port: 587
  username: ""
  password: ""
  from: ""
